# Application
APP_NAME=Campus Guardian AI
APP_ENV=development
DEBUG=true

# Backend
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=campus_guardian_ai
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/campus_guardian_ai

# AI Engine
CAMERA_SOURCE=0
MODEL_PATH=models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# Storage
SNAPSHOT_DIR=data/snapshots
OUTPUT_DIR=data/outputs

# Security
SECRET_KEY=change_this_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60